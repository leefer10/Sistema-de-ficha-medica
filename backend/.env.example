# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/sistema_salud_db

# Google Cloud Vision API
# OPTION 1: Usar archivo JSON (si se copia al container)
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/google-credentials.json

# OPTION 2: Usar JSON como variable de entorno (RECOMENDADO para Railway)
# Copiar todo el contenido del JSON aquí sin saltos de línea
GOOGLE_CREDENTIALS_JSON={}

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# JWT Secret
SECRET_KEY=your-super-secret-key-change-this-in-production

# Environment
ENVIRONMENT=production
